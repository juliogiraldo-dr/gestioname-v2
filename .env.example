# App
APP_NAME="Gestioname v2"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Multi-tenancy
TENANT_DOMAIN=localhost

# Base de datos
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gestioname
DB_USERNAME=gestioname
DB_PASSWORD=secret

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Email (Mailpit en desarrollo)
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_FROM_ADDRESS=noreply@gestioname.app
MAIL_FROM_NAME="Gestioname"

# Sanctum
SANCTUM_STATEFUL_DOMAINS=localhost:3000,demo.localhost:3000
SESSION_DOMAIN=localhost

# Storage
FILESYSTEM_DISK=local

# Frontend
FRONTEND_URL=http://localhost:3000

# Stripe (vacío en desarrollo)
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# MinIO / S3 (vacío en desarrollo)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=gestioname
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true
