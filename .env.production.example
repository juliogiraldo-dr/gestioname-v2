# ─── Gestioname v2 · Variables de producción (deploy.datarecover.cloud) ───
# Copia a .env en el servidor y rellena los valores reales. NO comitear el .env real.

# Aplicación
APP_NAME=Gestioname
APP_ENV=production
APP_KEY=                       # generar con: php artisan key:generate --show
APP_DEBUG=false
APP_URL=https://api.gestioname.app
APP_FRONTEND_URL=https://gestioname.app   # base para los magic links

# Dominio principal (Traefik enruta *.gestioname.app)
ROOT_DOMAIN=gestioname.app
LETSENCRYPT_EMAIL=ops@datarecover.es

# Base de datos (PostgreSQL 16, multi-tenant por schemas)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=gestioname
DB_USERNAME=gestioname
DB_PASSWORD=                   # contraseña fuerte

# Redis (caché + colas + sesiones)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=                # contraseña fuerte

CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# Correo (SMTP real en producción; Mailpit solo en dev)
MAIL_MAILER=smtp
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=no-reply@gestioname.app
MAIL_FROM_NAME=Gestioname

# Frontend (Next.js) — la API se sirve en el mismo origen bajo /api (el subdominio
# identifica al tenant), por eso la URL es relativa y NO se fija NEXT_PUBLIC_TENANT.
NEXT_PUBLIC_API_URL=/api/v1
NEXT_PUBLIC_TENANT=
